{
  "name": "claude-inspect",
  "version": "2.0.0",
  "description": "Claude Code CLI for frontend development - visual element selection, component detection, browser monitoring",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "claude-inspect": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "skills",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "browser",
    "frontend",
    "devtools",
    "react",
    "vue",
    "component-detection",
    "playwright"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tnsqjahong/claude-inspect.git"
  },
  "homepage": "https://github.com/tnsqjahong/claude-inspect#readme",
  "bugs": {
    "url": "https://github.com/tnsqjahong/claude-inspect/issues"
  },
  "license": "MIT",
  "author": "tnsqjahong",
  "dependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
